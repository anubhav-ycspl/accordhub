#: includes/admin/views/html-ph-booking-settings-display-customiser.php:354
msgid "Enabling this option will allow clients to see the calendar in their own time zone."
msgstr "Włączenie tej opcji pozwoli klientom zobaczyć kalendarz we własnej strefie czasowej."

#: includes/admin/views/html-ph-booking-product-admin-icalendar.php:43
msgid "Enabling this option will allow you to export the booking events to your iCalendar via .ics file"
msgstr "Włączenie tej opcji pozwoli na eksport zdarzeń rezerwacyjnych do iCalendar poprzez plik .ics"

#: includes/admin/views/html-ph-booking-settings-outlook.php:77
msgid "Enabling this option will allow you to sync booking events to your MS Outlook calendar"
msgstr "Włączenie tej opcji pozwoli na synchronizację zdarzeń rezerwacyjnych do kalendarza MS Outlook"

#: includes/admin/views/html-ph-booking-settings-google-calendar.php:108
msgid "Enabling this option will allow your customers to add the booking as an event to their google calendar"
msgstr "Włączenie tej opcji pozwoli Twoim klientom dodać rezerwację jako wydarzenie do ich kalendarza Google"

#: includes/admin/views/html-ph-booking-product-admin-icalendar.php:52
msgid "Enabling this option will allow your customers to export the booking events to your iCalendar via .ics file from their My Accounts page"
msgstr "Włączenie tej opcji pozwoli klientom na eksport zdarzeń rezerwacji do iCalendar poprzez plik .ics z ich strony Moje konta"

#: includes/admin/views/html-ph-booking-product-admin-persons.php:45
msgid "Enabling this option will create a separate booking order for each participant"
msgstr "Włączenie tej opcji spowoduje utworzenie osobnego zamówienia rezerwacji dla każdego uczestnika"

#: includes/admin/views/html-ph-booking-product-admin-availability.php:135
msgid "Enabling this option will disable all dates in the calendar. Using this option with availability rules, you can enable desired dates for bookings."
msgstr "Włączenie tej opcji spowoduje wyłączenie wszystkich dat w kalendarzu. Korzystając z tej opcji z regułami dostępności, możesz włączyć pożądane daty rezerwacji."

#: includes/admin/views/html-ph-booking-product-admin-options.php:140
msgid "Enabling this option will select the Minimum Booking Slots automatically as soon as the customer selects the first slot."
