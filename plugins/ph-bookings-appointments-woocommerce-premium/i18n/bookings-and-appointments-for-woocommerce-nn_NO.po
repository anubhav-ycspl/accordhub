#: includes/admin/views/html-ph-booking-settings-availability.php:54
#: includes/admin/views/html-ph-booking-product-admin-availability.php:125
msgid "1. All dates are available by default. Create rules to set the time period when you are not available to take bookings."
msgstr "1. Alle datoer er tilgjengelige som standard. Opprett regler for å angi tidsperioden når du ikke er tilgjengelig for å ta bestillinger."

#: includes/admin/views/html-ph-booking-settings-availability.php:56
#: includes/admin/views/html-ph-booking-product-admin-availability.php:127
msgid "2. Mark all the dates/blocks as unavailable and then set the time period when you are available for bookings."
msgstr "2. Merk alle datoene / blokkene som utilgjengelige og sett deretter tidsperioden når du er tilgjengelig for bestilling."

#: includes/admin/views/html-ph-booking-product-admin-options.php:74
msgid "<br><span style='float:left;'><i>Fixed Blocks : Customers can book one block at a time.<br>Enable Range : Customers can book multiple blocks by choosing a start and an end.</i></span>"
msgstr "<br> <span style=\"float:left;\"><i>Faste blokker: Kunder kan bestille en blokk om gangen. <br> Aktiver rekkevidde: Kunder kan bestille flere blokker ved å velge en start og en slutt.</i></span>"

#: includes/admin/views/html-ph-booking-product-admin-resources.php:28
msgid "<h4><b>Single Resource</b> - Customers can choose One Resource from a Drop Down containing all the resources. </h4><h4><b>Multiple Resources</b> - Customers can select Multiple Resource while booking.</h4>"
msgstr "<h4> <b> Enkelt ressurs </b> - Kunder kan velge én ressurs fra en rullegardin som inneholder alle ressursene. </h4><h4> <b> Flere ressurser </b> - Kunder kan velge flere ressurser mens de booker. </h4>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:196
msgid "<span style='padding-left:2%; font-size:12px;'><i>Check this box if the booking requires admin approval/confirmation.</i></span>"
msgstr "<span style='padding-left:2%; font-size:12px;'><i>Merk av for denne boksen hvis bestillingen krever administrasjonsgodkjenning / bekreftelse.</i></span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:81
msgid "<span style='padding-left:2%;'><i>Allow multiple bookings for the same block until the specified number is reached.</i></span>"
msgstr "<span style='padding-left:2%;'><i>Tillat flere bestillinger for samme blokk til det angitte nummeret er nådd.</i></span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:137
msgid "<span style='padding-left:2%;'><i>Auto-Select Minimum Booking Slots.</i></span>"
msgstr "<span style = 'padding-left: 2%;'> <i> Auto-Select Minimum Booking Slots. </i> </span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:202
msgid "<span style='padding-left:2%;'><i>Enable this option to offer bookings on a per night basis. For Eg : Accommodations. The customer can choose a check in and check out date.</i></span>"
msgstr "<span style='padding-left:2%;'><i>Aktiver dette alternativet for å bestille bestillinger per natt. For eksempel: Overnattingssteder. Kunden kan velge innsjekkings- og utsjekkingsdato.</i></span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:281
msgid "<span style='padding-left:2%;'><i>Enabling this option will allow customers to book timeslots across days. For Eg : 9.00 Am , 1st May to 6.00 Pm 2nd May.</i></span>"
msgstr "<span style = 'padding-left: 2%;'> <i> Hvis du aktiverer dette alternativet, kan kundene bestille timeslots over flere dager. For f.eks: kl. 9.00, 1. mai til kl. 06.00 2. mai. </i> </span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:295
msgid "<span style='padding-left:2%;'><i>Enabling this option will display both the Booking Slot Start Time as well as End Time on the calendar.</i></span>"
msgstr "<span style = 'padding-left: 2%;'> <i> Hvis du aktiverer dette alternativet, vises både starttidspunktet for sluttplasseringen og sluttiden i kalenderen. </i> </span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:109
msgid "<span style='padding-left:2%;'><i>Enabling this will show the Fully Booked Indicator for bookings slots which is fully booked.</i><span>"
msgstr "<span style='padding-left:2%;'><i> Hvis du aktiverer dette, vil du vise Fully Booked Indicator for bestillingsslots som er fullt booket.</i><span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:88
msgid "<span style='padding-left:2%;'><i>Enabling this will show the number of places left for bookings per block.</i><span>"
msgstr "<span style='padding-left:2%;'><i>Aktivering av dette vil vise antall steder igjen for bestillinger per blokk.</i></span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:209
msgid "<span style='padding-left:2%;'><i>Hide checkout date on admin calendar and google calendar for per night bookings.</i></span>"
msgstr "<span style='padding-left:2%;'><i>Skjul utsjekkingsdatoen på administratorkalenderen og Google-kalenderen for bestillinger per natt.</i></span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:146
msgid "<span style='padding-left:2%;'><i>Set the maximum period the customer can input. Leave blank for unlimited.</i></span>"
msgstr "<span style = 'padding-left: 2%;'> <i> Angi den maksimale perioden kunden kan legge inn. La være tom for ubegrenset. </ I> </ span>"

#: includes/admin/views/html-ph-booking-product-admin-options.php:131
msgid "<span style='padding-left:2%;'><i>Set the minimum booking period the customer can select.</i></span>"
msgstr "<span style='padding-left:2%;'><i>Angi den minste bestillingsperioden kunden kan velge.</i></span>"

#: includes/admin/views/html-ph-booking-settings-display-customiser.php:484
msgid "<strong>Direct Booking:</strong> Display booking details directly without a calendar for modifications."
msgstr "<strong>Direkt bestilling:</strong> Vis bestillingsdetaljer direkte uten kalender for endringer."

#: includes/admin/views/html-ph-booking-settings-display-customiser.php:482
msgid "<strong>Flexible Booking:</strong> Display booking details along with a calendar for editing and modifying."
msgstr "<strong>Fleksibel bestilling:</strong> Vis bestillingsdetaljer sammen med en kalender for redigering og endring."

